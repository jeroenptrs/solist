{
  "name": "solist-agent",
  "version": "0.1.0",
  "description": "Solo orchestration CLI powered by Pi.",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeroenptrs/solist.git"
  },
  "bugs": {
    "url": "https://github.com/jeroenptrs/solist/issues"
  },
  "homepage": "https://github.com/jeroenptrs/solist#readme",
  "keywords": [
    "solo",
    "codex",
    "orchestration",
    "cli",
    "agents"
  ],
  "bin": {
    "solist": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && tsc -p tsconfig.build.json && pnpm run chmod-bin",
    "chmod-bin": "node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "check": "pnpm run typecheck && pnpm test",
    "solist": "node dist/cli.js",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "pnpm run check && pnpm run build",
    "prepare": "pnpm run build"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
